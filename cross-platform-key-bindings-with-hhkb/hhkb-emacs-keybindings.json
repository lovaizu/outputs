{
  "title": "HHKB Emacs Keybindings",
  "rules": [
    {
      "description": "HHKB only — apply when HHKB Studio is connected",
      "manipulators": [
        {
          "description": "IME: SPR (Kana) passthrough — switch to Japanese",
          "type": "basic",
          "from": { "key_code": "japanese_kana" },
          "to": [{ "key_code": "japanese_kana" }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },

        {
          "description": "App: SPL+Tab (Opt+Tab) → Cmd+Tab (AltTab app)",
          "type": "basic",
          "from": { "key_code": "tab", "modifiers": { "mandatory": ["option"], "optional": ["any"] } },
          "to": [{ "key_code": "tab", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "App: SPL+SP (Opt+Space) → Cmd+Space (Spotlight)",
          "type": "basic",
          "from": { "key_code": "spacebar", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "spacebar", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "App: SPL+Q (Opt+Q) → Cmd+Q (Quit)",
          "type": "basic",
          "from": { "key_code": "q", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "q", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },

        {
          "description": "Window: SPL+N (Opt+N) → Cmd+N (New window)",
          "type": "basic",
          "from": { "key_code": "n", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "n", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "Window/Tab: SPL+K (Opt+K) → Cmd+W (Close window or tab)",
          "type": "basic",
          "from": { "key_code": "k", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "w", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "Window: SPL+M (Opt+M) → Cmd+M (Minimize)",
          "type": "basic",
          "from": { "key_code": "m", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "m", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "Window: Ctrl+SPL+F (Ctrl+Opt+F) → Ctrl+Cmd+F (Fullscreen)",
          "type": "basic",
          "from": { "key_code": "f", "modifiers": { "mandatory": ["control", "option"] } },
          "to": [{ "key_code": "f", "modifiers": ["control", "command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },

        {
          "description": "Tab: SPL+T (Opt+T) → Cmd+T (New tab)",
          "type": "basic",
          "from": { "key_code": "t", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "t", "modifiers": ["command"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "Tab: SPL+Shift+T (Opt+Shift+T) → Cmd+Shift+T (Reopen closed tab)",
          "type": "basic",
          "from": { "key_code": "t", "modifiers": { "mandatory": ["option", "shift"] } },
          "to": [{ "key_code": "t", "modifiers": ["command", "shift"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },

        {
          "description": "SS: SPL2+PS (Fn1+`) → Cmd+Ctrl+Shift+3 (Full screen capture)",
          "type": "basic",
          "from": { "key_code": "print_screen" },
          "to": [{ "key_code": "3", "modifiers": ["command", "control", "shift"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "SS: SPL2+PS+S (Fn1+`+S) → Cmd+Ctrl+Shift+4 (Region capture)",
          "type": "basic",
          "from": { "key_code": "print_screen", "modifiers": { "mandatory": ["shift"] } },
          "to": [{ "key_code": "4", "modifiers": ["command", "control", "shift"] }],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        },
        {
          "description": "SS: SPL2+PS+W (Fn1+`+W) → Cmd+Ctrl+Shift+4 then Space (Window capture)",
          "type": "basic",
          "from": { "key_code": "print_screen", "modifiers": { "mandatory": ["option"] } },
          "to": [
            { "key_code": "4", "modifiers": ["command", "control", "shift"] },
            { "key_code": "spacebar" }
          ],
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        }
      ]
    },
    {
      "description": "Edit (Emacs) — all apps except terminal/editor apps",
      "manipulators": [
        {
          "description": "Edit: SPL+F (Opt+F / M-f) → Opt+→ (word forward)",
          "type": "basic",
          "from": { "key_code": "f", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "right_arrow", "modifiers": ["option"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+B (Opt+B / M-b) → Opt+← (word backward)",
          "type": "basic",
          "from": { "key_code": "b", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "left_arrow", "modifiers": ["option"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+V (Opt+V / M-v) → Page Up",
          "type": "basic",
          "from": { "key_code": "v", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "page_up" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+D (Opt+D / M-d) → Opt+→ then Delete (word kill forward)",
          "type": "basic",
          "from": { "key_code": "d", "modifiers": { "mandatory": ["option"] } },
          "to": [
            { "key_code": "right_arrow", "modifiers": ["option"] },
            { "key_code": "delete_or_backspace", "modifiers": ["option"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+DEL (Opt+DEL / M-DEL) → Opt+Backspace (word kill backward)",
          "type": "basic",
          "from": { "key_code": "delete_or_backspace", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "delete_or_backspace", "modifiers": ["option"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+K → Shift+End then Cmd+X (kill to EOL)",
          "type": "basic",
          "from": { "key_code": "k", "modifiers": { "mandatory": ["control"] } },
          "to": [
            { "key_code": "end", "modifiers": ["shift"] },
            { "key_code": "x", "modifiers": ["command"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+G → → (clear mark / deselect)",
          "type": "basic",
          "from": { "key_code": "g", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "right_arrow" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+W (Opt+W / M-w) → Cmd+C (copy region)",
          "type": "basic",
          "from": { "key_code": "w", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "c", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+W → Cmd+X (cut region)",
          "type": "basic",
          "from": { "key_code": "w", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "x", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+Y → Cmd+V (paste)",
          "type": "basic",
          "from": { "key_code": "y", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "v", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+/ → Cmd+Z (undo)",
          "type": "basic",
          "from": { "key_code": "slash", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "z", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: Ctrl+Shift+/ → Cmd+Shift+Z (redo)",
          "type": "basic",
          "from": { "key_code": "slash", "modifiers": { "mandatory": ["control", "shift"] } },
          "to": [{ "key_code": "z", "modifiers": ["command", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        },
        {
          "description": "Edit: SPL+Shift+5 (Opt+Shift+5 / M-%) → query replace (passthrough for app to handle)",
          "type": "basic",
          "from": { "key_code": "5", "modifiers": { "mandatory": ["option", "shift"] } },
          "to": [{ "key_code": "5", "modifiers": ["option", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$", "^com\\.mitchellh\\.ghostty$", "^com\\.apple\\.Terminal$"] }
          ]
        }
      ]
    },
    {
      "description": "File / Pane: Ctrl+X prefix sequences",
      "manipulators": [
        {
          "description": "File: Ctrl+X Ctrl+F → Cmd+O (open file)",
          "type": "basic",
          "from": { "key_code": "f", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "o", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "File: Ctrl+X Ctrl+S → Cmd+S (save)",
          "type": "basic",
          "from": { "key_code": "s", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "s", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "File: Ctrl+X Ctrl+W → Cmd+Shift+S (save as)",
          "type": "basic",
          "from": { "key_code": "w", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "key_code": "s", "modifiers": ["command", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "File: Ctrl+X K → Cmd+W (close file/tab)",
          "type": "basic",
          "from": { "key_code": "k" },
          "to": [{ "key_code": "w", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "File: Ctrl+X B → Cmd+T (switch tab/buffer)",
          "type": "basic",
          "from": { "key_code": "b" },
          "to": [{ "key_code": "t", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "File: Ctrl+X H → Cmd+A (select all)",
          "type": "basic",
          "from": { "key_code": "h" },
          "to": [{ "key_code": "a", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 }
          ]
        },
        {
          "description": "Pane (VS Code): Ctrl+X 2 → Cmd+K Cmd+\\ (horizontal split)",
          "type": "basic",
          "from": { "key_code": "2" },
          "to": [
            { "key_code": "k", "modifiers": ["command"] },
            { "key_code": "backslash", "modifiers": ["command"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$"] }
          ]
        },
        {
          "description": "Pane (Terminal): Ctrl+X 2 → Cmd+D (horizontal split)",
          "type": "basic",
          "from": { "key_code": "2" },
          "to": [{ "key_code": "d", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.mitchellh\\.ghostty$"] }
          ]
        },
        {
          "description": "Pane (VS Code): Ctrl+X 3 → Cmd+K Cmd+- (vertical split)",
          "type": "basic",
          "from": { "key_code": "3" },
          "to": [
            { "key_code": "k", "modifiers": ["command"] },
            { "key_code": "hyphen", "modifiers": ["command"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$"] }
          ]
        },
        {
          "description": "Pane (Terminal): Ctrl+X 3 → Cmd+Shift+D (vertical split)",
          "type": "basic",
          "from": { "key_code": "3" },
          "to": [{ "key_code": "d", "modifiers": ["command", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.mitchellh\\.ghostty$"] }
          ]
        },
        {
          "description": "Pane (VS Code): Ctrl+X O → Cmd+K Cmd+→ (next pane)",
          "type": "basic",
          "from": { "key_code": "o" },
          "to": [
            { "key_code": "k", "modifiers": ["command"] },
            { "key_code": "right_arrow", "modifiers": ["command"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "variable_if", "name": "ctrl_x_pressed", "value": 1 },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.microsoft\\.VSCode$"] }
          ]
        },
        {
          "description": "Ctrl+X — set prefix state (must be last to not shadow the above)",
          "type": "basic",
          "from": { "key_code": "x", "modifiers": { "mandatory": ["control"] } },
          "to": [{ "set_variable": { "name": "ctrl_x_pressed", "value": 1 } }],
          "to_delayed_action": {
            "to_if_invoked": [{ "set_variable": { "name": "ctrl_x_pressed", "value": 0 } }],
            "to_if_canceled": [{ "set_variable": { "name": "ctrl_x_pressed", "value": 0 } }]
          },
          "conditions": [{ "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] }]
        }
      ]
    },
    {
      "description": "Browser (Chrome only)",
      "manipulators": [
        {
          "description": "Browser: SPL+R (Opt+R) → Cmd+R (reload)",
          "type": "basic",
          "from": { "key_code": "r", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "r", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.google\\.Chrome$"] }
          ]
        },
        {
          "description": "Browser: SPL+L (Opt+L) → Cmd+L (focus URL bar)",
          "type": "basic",
          "from": { "key_code": "l", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "l", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.google\\.Chrome$"] }
          ]
        },
        {
          "description": "Browser: SPL+I (Opt+I) → Cmd+D (bookmark)",
          "type": "basic",
          "from": { "key_code": "i", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "d", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.google\\.Chrome$"] }
          ]
        },
        {
          "description": "Browser: SPL+← (Opt+←) → Cmd+← (back)",
          "type": "basic",
          "from": { "key_code": "left_arrow", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "left_arrow", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.google\\.Chrome$"] }
          ]
        },
        {
          "description": "Browser: SPL+→ (Opt+→) → Cmd+→ (forward)",
          "type": "basic",
          "from": { "key_code": "right_arrow", "modifiers": { "mandatory": ["option"] } },
          "to": [{ "key_code": "right_arrow", "modifiers": ["command"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1278, "product_id": 22 }] },
            { "type": "frontmost_application_if", "bundle_identifiers": ["^com\\.google\\.Chrome$"] }
          ]
        }
      ]
    }
  ]
}
